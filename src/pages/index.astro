---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCard from '../components/PhotoCard.astro';
import PlaceholderPhoto from '../components/PlaceholderPhoto.astro';
import ObfuscatedEmail from '../components/ObfuscatedEmail.astro';
import { photos, categories } from '../data/photos';

// Only show pills for categories that actually have photos in the catalog.
const activeCategories = categories.filter((c) => photos.some((p) => p.category === c));

// Unique countries derived from the last segment of each photo's location field.
const countries = [...new Set(
  photos
    .map((p) => (p.location ?? '').split(',').map((s: string) => s.trim()).at(-1) ?? '')
    .filter(Boolean)
)].sort() as string[];

// Unique years derived from photo dates, descending.
const years = [...new Set(
  photos
    .map((p) => p.date ? String(new Date(p.date).getFullYear()) : '')
    .filter(Boolean)
)].sort((a, b) => Number(b) - Number(a)) as string[];

// Replace with your real Formspree endpoint
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xwvyqeje';

// Hero background — set to a path under /public to use a real photo
// (recommended: 2560x1440 or larger, JPEG q=85). Leave undefined to use
// the procedural SVG placeholder.
const HERO_PHOTO: string | undefined = '/photos/forbidden-city.jpg';
// Example:
// const HERO_PHOTO = '/photos/hero-2560.jpg';
const avatar={
    id: 'small',
    src: '/photos/small.jpg',
    title: '',
    category: '',
    date: '2024-11-04', location: 'Shanghai, China',
    camera: 'Apple iPhone 15 Pro Max',
    lens: '120mm equiv. f/2.8',                         // 5× telephoto module
    exposure: '1/6900s · f/2.8 · ISO 64',
    preset: 'ocean', palette: 'sage', aspect: 'tall',
    featured: true,
    alt: 'Kelingking Beach from above, iPhone 15 Pro Max telephoto, November 2024',
  }
---
<BaseLayout title="Lyndon Vision · Photography">
  {/* ── HERO ─────────────────────────────────────────────── */}
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true">
      {HERO_PHOTO
        ? <img src={HERO_PHOTO} alt="" fetchpriority="high" decoding="async" />
        : <PlaceholderPhoto preset="mountain" palette="midnight" seed="hero-2026" />}
    </div>
    <div class="container">
      <span class="eyebrow">Photography Portfolio · vol. 07</span>
      <h1>
        Capturing
        <span class="accent">Raw Moments</span>
      </h1>
      <p class="lede">
        Landscapes, portraits, street, architecture, and macro—an exploration across light, form, and fleeting moments.
      </p>
      <p class="muted">
        From sweeping vistas to intimate human expressions, each frame is shaped with tools from Hasselblad, Leica, Sony, and Fujifilm, with the occasional roll of 135 film lending its quiet, tactile depth.
      </p>
      <div class="hero-ctas">
        <a href="#work" class="btn">View Work <span class="arrow">→</span></a>
        <a href="#contact" class="btn btn--ghost">Get in touch</a>
      </div>
      <div class="meta">
        <span class="bar"></span>
        <span>Based in Singapore · Available worldwide</span>
      </div>
    </div>
    <div class="scroll-hint" aria-hidden="true">scroll</div>
  </section>

  {/* ── WORK ─────────────────────────────────────────────── */}
  <section class="section" id="work">
    <div class="container">
      <div class="section-head reveal">
        <div class="left">
          <span class="eyebrow muted">No. 01 — Portfolio</span>
          <h2>Selected Work</h2>
          <p class="muted" style="margin-top: 1rem;">
            Browse by category. Each work shows location and year — click for details.
          </p>
        </div>
        <span class="index">{photos.length} works on file</span>
      </div>

      <div class="filters reveal" id="filters">
        <button class="filter-pill active" data-filter="featured" data-type="special" role="tab" aria-selected="true">Featured</button>

        <div class="fdd" id="fdd">
          <button class="fdd-btn" id="fdd-btn" aria-expanded="false" aria-haspopup="true">
            Browse <span class="fdd-arrow">▾</span>
          </button>
          <div class="fdd-panel" id="fdd-panel" hidden>
            <div class="fdd-group">
              <span class="fdd-label">Category</span>
              <div class="fdd-items">
                {activeCategories.map((c) => (
                  <button class="fdd-item" data-filter={c} data-type="category">{c}</button>
                ))}
              </div>
            </div>
            <div class="fdd-group">
              <span class="fdd-label">Location</span>
              <div class="fdd-items">
                {countries.map((c) => (
                  <button class="fdd-item" data-filter={c} data-type="location">{c}</button>
                ))}
              </div>
            </div>
            <div class="fdd-group">
              <span class="fdd-label">Year</span>
              <div class="fdd-items">
                {years.map((y) => (
                  <button class="fdd-item" data-filter={y} data-type="year">{y}</button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        .fdd { position: relative; display: inline-block; z-index: 100; }

        .fdd-btn {
          display: inline-flex; align-items: center; gap: 0.4rem;
          padding: 0.4rem 1rem;
          font-family: var(--font-mono, monospace);
          font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase;
          border: 1px solid rgba(255,255,255,0.18);
          border-radius: 2rem;
          background: transparent; color: rgba(255,255,255,0.55);
          cursor: pointer; transition: color 0.15s, border-color 0.15s;
          white-space: nowrap;
        }
        .fdd-btn:hover, .fdd-btn.fdd-active { color: #fff; border-color: rgba(255,255,255,0.5); }
        .fdd-btn.fdd-active { background: rgba(255,255,255,0.08); }
        .fdd-arrow { font-size: 0.65rem; transition: transform 0.15s; }
        .fdd-btn[aria-expanded="true"] .fdd-arrow { transform: rotate(180deg); }

        .fdd-panel {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          z-index: 200;
          background: #111;
          border: 1px solid rgba(255,255,255,0.12);
          border-radius: 0.5rem;
          padding: 1rem 1.2rem;
          min-width: 240px;
          display: flex; flex-direction: column; gap: 1rem;
          box-shadow: 0 8px 32px rgba(0,0,0,0.5);
          z-index: 500;
        }
        .fdd-panel[hidden] { display: none !important; }

        .fdd-label {
          display: block;
          font-family: var(--font-mono, monospace);
          font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
          color: rgba(255,255,255,0.3);
          margin-bottom: 0.5rem;
        }

        .fdd-items { display: flex; flex-wrap: wrap; gap: 0.4rem; }

        .fdd-item {
          padding: 0.3rem 0.75rem;
          font-family: var(--font-mono, monospace);
          font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
          border: 1px solid rgba(255,255,255,0.15);
          border-radius: 2rem;
          background: transparent; color: rgba(255,255,255,0.5);
          cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s;
          white-space: nowrap;
        }
        .fdd-item:hover { color: #fff; border-color: rgba(255,255,255,0.4); }
        .fdd-item.fdd-item-active {
          color: #fff; border-color: rgba(255,255,255,0.7);
          background: rgba(255,255,255,0.1);
        }
      </style>

      <div class="photo-grid" id="grid">
        {photos.map((photo) => <PhotoCard photo={photo} />)}
      </div>
    </div>

    <script is:inline>
      (() => {
        const grid    = document.getElementById('grid');
        const fddBtn  = document.getElementById('fdd-btn');
        const fddPanel= document.getElementById('fdd-panel');
        const featBtn = document.querySelector('[data-filter="featured"]');
        if (!grid || !fddBtn || !fddPanel || !featBtn) return;

        // ── filter logic ──────────────────────────────────────
        function applyFilter(value, type) {
          grid.querySelectorAll('.photo-card').forEach((card) => {
            let show;
            if (type === 'special') {         // Featured
              show = card.getAttribute('data-featured') === 'true';
            } else if (type === 'category') {
              show = card.getAttribute('data-category') === value;
            } else if (type === 'location') {
              const loc = (card.getAttribute('data-location') || '').split(',').map(s => s.trim()).at(-1) || '';
              show = loc === value;
            } else if (type === 'year') {
              const dateStr = card.getAttribute('data-date') || '';
              const yr = dateStr ? String(new Date(dateStr).getFullYear()) : '';
              show = yr === value;
            }
            card.setAttribute('data-hidden', show ? 'false' : 'true');
          });
        }

        // ── active state helpers ───────────────────────────────
        function setFeaturedActive() {
          featBtn.classList.add('active');
          featBtn.setAttribute('aria-selected', 'true');
          fddBtn.classList.remove('fdd-active');
          fddBtn.childNodes[0].textContent = 'Browse ';
          document.querySelectorAll('.fdd-item').forEach(i => i.classList.remove('fdd-item-active'));
          closePanel();
        }

        function setDropdownActive(item, label) {
          featBtn.classList.remove('active');
          featBtn.setAttribute('aria-selected', 'false');
          fddBtn.classList.add('fdd-active');
          fddBtn.childNodes[0].textContent = label + ' ';
          document.querySelectorAll('.fdd-item').forEach(i => i.classList.remove('fdd-item-active'));
          item.classList.add('fdd-item-active');
          closePanel();
        }

        // ── dropdown open / close ──────────────────────────────
        function openPanel() {
          fddPanel.hidden = false;
          fddBtn.setAttribute('aria-expanded', 'true');
        }
        function closePanel() {
          fddPanel.hidden = true;
          fddBtn.setAttribute('aria-expanded', 'false');
        }
        function togglePanel() {
          fddPanel.hidden ? openPanel() : closePanel();
        }

        fddBtn.addEventListener('click', (e) => { e.stopPropagation(); togglePanel(); });
        document.addEventListener('click', (e) => {
          if (!fddPanel.hidden && !fddPanel.contains(e.target) && e.target !== fddBtn) closePanel();
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });

        // ── Featured button ────────────────────────────────────
        featBtn.addEventListener('click', () => {
          setFeaturedActive();
          applyFilter('featured', 'special');
        });

        // ── Dropdown items ─────────────────────────────────────
        document.querySelectorAll('.fdd-item').forEach((item) => {
          item.addEventListener('click', () => {
            const value = item.getAttribute('data-filter');
            const type  = item.getAttribute('data-type');
            setDropdownActive(item, value);
            applyFilter(value, type);
          });
        });

        // Apply initial Featured filter on page load
        applyFilter('featured', 'special');
      })();
    </script>
  </section>

  {/* ── PANORAMA ─────────────────────────────────────────── */}
  <section class="pano-section" id="panorama">
    <div class="pano-header reveal">
      <span class="eyebrow muted">No. 02 — Panorama</span>
      <h2>The Long Frame.</h2>
    </div>

    <div class="pano-viewport" id="panoViewport">
      <img
        id="panoImg"
        src="/photos/panorama.jpg"
        alt="Panorama"
        draggable="false"
        loading="lazy"
        decoding="async"
      />
      <div class="pano-hint" id="panoHint">drag to explore →</div>
      <div class="pano-overlay">
        <span class="pano-ov-category">Street</span>
        <h3 class="pano-ov-title">Bund</h3>
        <span class="pano-ov-where">Shanghai · 2024</span>
      </div>
    </div>

    <div class="pano-bar">
      <div class="pano-progress" id="panoProgress"></div>
    </div>

    <div class="pano-meta reveal">
      <span class="pano-meta-title">Panorama</span>
      <span class="pano-meta-detail">56247 × 8038 px</span>
    </div>
  </section>

  <style>
    .pano-section {
      padding: 5rem 0 0;
    }
    .pano-header {
      padding: 0 var(--gutter, 2rem);
      margin-bottom: 2.5rem;
    }
    .pano-viewport {
      position: relative;
      width: 100%;
      height: 55vh;
      min-height: 280px;
      overflow: hidden;
      cursor: grab;
      background: #000;
      user-select: none;
    }
    .pano-viewport.grabbing { cursor: grabbing; }
    .pano-viewport img {
      height: 100%;
      width: auto;
      max-width: none;
      display: block;
      pointer-events: none;
      will-change: transform;
    }
    .pano-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      padding: 1.5rem 1.6rem;
      pointer-events: none;
    }
    .pano-ov-category {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }
    .pano-ov-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.4rem;
      letter-spacing: -0.01em;
      font-weight: 400;
      color: var(--ink);
      margin: 0 0 0.3rem;
    }
    .pano-ov-where {
      display: block;
      font-size: 0.78rem;
      color: var(--ink-soft);
    }
    .pano-hint {
      position: absolute;
      bottom: 1.5rem;
      right: 2rem;
      font-family: var(--font-mono, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      opacity: 1;
      transition: opacity 0.6s ease;
      pointer-events: none;
    }
    .pano-hint.hidden { opacity: 0; }
    .pano-bar {
      width: 100%;
      height: 2px;
      background: rgba(255,255,255,0.08);
    }
    .pano-progress {
      height: 100%;
      width: 0%;
      background: var(--gold, #c8a86a);
      transition: width 0.05s linear;
    }
    .pano-meta {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      padding: 1rem var(--gutter, 2rem) 5rem;
    }
    .pano-meta-title {
      font-family: var(--font-display, serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--ink, #f4f1ea);
    }
    .pano-meta-detail {
      font-family: var(--font-mono, monospace);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
  </style>

  <script is:inline>
    (() => {
      const vp       = document.getElementById('panoViewport');
      const img      = document.getElementById('panoImg');
      const progress = document.getElementById('panoProgress');
      const hint     = document.getElementById('panoHint');
      if (!vp || !img || !progress || !hint) return;

      let x = 0;            // current translate X (px, negative = scrolled right)
      let maxX = 0;         // -(imgWidth - vpWidth), always negative
      let startX = 0;       // pointer start X
      let startTx = 0;      // translate X at pointer-down
      let dragging = false;
      let velX = 0;
      let lastX = 0;
      let lastT = 0;
      let rafId = null;
      let hinted = false;

      function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

      function setX(val) {
        x = clamp(val, maxX, 0);
        img.style.transform = `translateX(${x}px)`;
        const pct = maxX < 0 ? (-x / -maxX) * 100 : 0;
        progress.style.width = pct + '%';
      }

      function updateMax() {
        maxX = Math.min(0, vp.offsetWidth - img.naturalWidth * (vp.offsetHeight / img.naturalHeight));
      }

      // Inertia loop
      function inertia() {
        if (Math.abs(velX) < 0.3) return;
        velX *= 0.93;
        setX(x + velX);
        rafId = requestAnimationFrame(inertia);
      }

      // Pointer events (works for mouse + touch)
      vp.addEventListener('pointerdown', (e) => {
        cancelAnimationFrame(rafId);
        dragging = true;
        startX = e.clientX;
        startTx = x;
        lastX = e.clientX;
        lastT = Date.now();
        velX = 0;
        vp.classList.add('grabbing');
        vp.setPointerCapture(e.pointerId);

        if (!hinted) {
          hinted = true;
          hint.classList.add('hidden');
        }
      });

      vp.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const now = Date.now();
        const dt = now - lastT || 1;
        velX = (e.clientX - lastX) / dt * 16;
        lastX = e.clientX;
        lastT = now;
        setX(startTx + (e.clientX - startX));
      });

      vp.addEventListener('pointerup', () => {
        dragging = false;
        vp.classList.remove('grabbing');
        rafId = requestAnimationFrame(inertia);
      });

      vp.addEventListener('pointercancel', () => {
        dragging = false;
        vp.classList.remove('grabbing');
      });

      // Wheel horizontal scroll
      vp.addEventListener('wheel', (e) => {
        e.preventDefault();
        cancelAnimationFrame(rafId);
        setX(x - (e.deltaX || e.deltaY) * 1.2);
      }, { passive: false });

      // Keyboard (← →) when focused
      vp.setAttribute('tabindex', '0');
      vp.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft')  { cancelAnimationFrame(rafId); setX(x + 80); }
        if (e.key === 'ArrowRight') { cancelAnimationFrame(rafId); setX(x - 80); }
      });

      // Recalc on resize
      function onResize() { updateMax(); setX(x); }
      window.addEventListener('resize', onResize);

      // Init once image loads
      if (img.complete && img.naturalWidth) {
        updateMax();
      } else {
        img.addEventListener('load', updateMax);
      }

      // Auto-pan hint animation on idle
      setTimeout(() => {
        if (!hinted) hint.classList.add('hidden');
      }, 4000);
    })();
  </script>

  {/* ── ABOUT ────────────────────────────────────────────── */}
  <section class="section section--alt" id="about">
    <div class="container">
      <div class="about-split">
        <div class="reveal">
          <span class="eyebrow muted">No. 02 — About</span>
          <h2>The Photographer.</h2>
          <p>
            Lyndon is a Singapore-based photographer who has spent the past decade documenting the world through his lens—
from Aoraki / Mount Cook to West Lake, from the winds of California to the last falling sakura in Tokyo.
          </p>
          <p>
            Drifting between landscapes, portraits, and street, with macro and architecture as quieter, contemplative detours.
            My post-processing favors a warm, film-inspired tonality—where rich detail and high resolution meet a restrained, tactile aesthetic.
            Open for commissions: commercial projects and brand still life.
          </p>
          <div class="stats-row">
            <div class="stat">
              <div class="num"><span class="gold">4</span></div>
              <div class="label">Continents covered</div>
            </div>
            <div class="stat">
              <div class="num"><span class="gold">100</span><span style="font-family:var(--font-mono);font-size:0.45em;letter-spacing:0.12em;color:var(--ink-soft);vertical-align:middle;margin-left:0.15em;">MP</span></div>
              <div class="label">Medium format</div>
            </div>
            <div class="stat">
              <div class="num"><span class="gold">1000</span>+</div>
              <div class="label">Photos delivered</div>
            </div>
          </div>
        </div>
        <div class="about-portrait reveal" aria-hidden="true">
          <PhotoCard photo={avatar}/>
          {/* <PlaceholderPhoto preset="portrait" palette="amber" seed="lyndon-self-2" /> */}
        </div>
      </div>
    </div>
  </section>

  {/* ── CONTACT ──────────────────────────────────────────── */}
  <section class="section" id="contact">
    <div class="container">
      <div class="section-head reveal">
        <div class="left">
          <span class="eyebrow muted">No. 03 — Contact</span>
          <h2>Let&apos;s connect.</h2>
          <p>
            Available for commissions, collaborations, and print sales.
            Usually replied within 1–2 business days.
          </p>
        </div>
      </div>

      <div class="contact-grid">
        <div class="reveal">
          <ul class="contact-list">
            <li>
              <span class="label">Email</span>
              <ObfuscatedEmail email="ligabriel12@gmail.com" subject="Commission inquiry — Lyndon Vision" />
              <span class="arrow">→</span>
            </li>
            <li>
              <span class="label">Instagram</span>
              <a href="https://instagram.com/lyndonli12" rel="me noopener" target="_blank">@lyndonli12</a>
              <span class="arrow">→</span>
            </li>
            <li>
              <span class="label">Location</span>
              <a href="#" rel="noopener">Singapore</a>
              <span class="arrow">→</span>
            </li>
            <li>
              <span class="label">vCard</span>
              <a href="/lyndon-vision.vcf" download>Download (.vcf)</a>
              <span class="arrow">↓</span>
            </li>
          </ul>
        </div>

        <div class="reveal">
          <form class="form-grid" action={FORMSPREE_ENDPOINT} method="POST">
            <div>
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" placeholder="Your name" />
            </div>
            <div>
              <label for="reply">Email</label>
              <input id="reply" name="email" type="email" required autocomplete="email" placeholder="hello@you.com" />
            </div>
            <div class="full">
              <label for="subject">Subject</label>
              <input id="subject" name="subject" type="text" placeholder="Commission · Print · Collaboration" />
            </div>
            <div class="full">
              <label for="msg">Message</label>
              <textarea id="msg" name="message" required placeholder="Tell me about the project, timeline, and vibe…"></textarea>
            </div>
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <div class="full" style="display:flex; align-items:center; gap:1.2rem; flex-wrap:wrap;">
              <button type="submit" class="btn">Send <span class="arrow">→</span></button>
              <span class="muted" style="font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">
                Replied within 1–2 business days
              </span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* ── LIGHTBOX ─────────────────────────────────────────── */}
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo detail" hidden>
    <button id="lb-close" aria-label="Close">&times;</button>
    <button id="lb-prev" aria-label="Previous photo">&#8592;</button>
    <button id="lb-next" aria-label="Next photo">&#8594;</button>
    <div id="lb-inner">
      <div id="lb-img-wrap">
        <img id="lb-img" src="" alt="" />
      </div>
      <div id="lb-info">
        <div id="lb-meta-left">
          <p id="lb-title"></p>
          <p id="lb-location"></p>
        </div>
        <div id="lb-exif">
          <span id="lb-camera"></span>
          <span id="lb-lens"></span>
          <span id="lb-exposure"></span>
        </div>
      </div>
    </div>
  </div>

  <style>
    #lightbox {
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0, 0, 0, 0.92);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    #lightbox[hidden] { display: none !important; }
    #lightbox.lb-visible { opacity: 1; }

    #lb-close {
      position: fixed;
      top: 1.2rem;
      right: 1.5rem;
      background: none;
      border: none;
      color: #fff;
      font-size: 2rem;
      line-height: 1;
      cursor: pointer;
      opacity: 0.6;
      transition: opacity 0.15s;
      z-index: 1001;
    }
    #lb-close:hover { opacity: 1; }

    #lb-prev, #lb-next {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #fff;
      font-size: 2rem;
      line-height: 1;
      cursor: pointer;
      opacity: 0.4;
      transition: opacity 0.15s;
      z-index: 1001;
      padding: 1rem 1.2rem;
      user-select: none;
    }
    #lb-prev { left: 0.5rem; }
    #lb-next { right: 0.5rem; }
    #lb-prev:hover, #lb-next:hover { opacity: 1; }
    #lb-prev[hidden], #lb-next[hidden] { display: none !important; }

    #lb-inner {
      display: flex;
      flex-direction: column;
      max-width: min(1100px, 96vw);
      max-height: 92vh;
      width: 100%;
    }

    #lb-img-wrap {
      flex: 1;
      min-height: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    #lb-img {
      max-width: 100%;
      max-height: calc(92vh - 7rem);
      object-fit: contain;
      display: block;
      border-radius: 2px;
    }

    #lb-info {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 1rem 0.25rem 0;
      flex-shrink: 0;
      flex-wrap: wrap;
    }

    #lb-meta-left { flex: 1; min-width: 0; }

    #lb-title {
      font-family: var(--font-display, serif);
      font-size: 1.15rem;
      font-style: italic;
      color: #fff;
      margin: 0 0 0.15rem;
    }

    #lb-location {
      font-family: var(--font-mono, monospace);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      margin: 0;
    }

    #lb-exif {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.15rem;
      font-family: var(--font-mono, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.38);
      text-align: right;
    }

    #lb-exif span:empty { display: none; }

    @media (max-width: 600px) {
      #lb-info { flex-direction: column; align-items: flex-start; }
      #lb-exif { align-items: flex-start; text-align: left; }
      #lb-prev { left: 0; }
      #lb-next { right: 0; }
    }
  </style>

  <script is:inline>
    (() => {
      const lb      = document.getElementById('lightbox');
      const lbImg   = document.getElementById('lb-img');
      const lbTitle = document.getElementById('lb-title');
      const lbLoc   = document.getElementById('lb-location');
      const lbCam   = document.getElementById('lb-camera');
      const lbLens  = document.getElementById('lb-lens');
      const lbExp   = document.getElementById('lb-exposure');
      const lbClose = document.getElementById('lb-close');
      const lbPrev  = document.getElementById('lb-prev');
      const lbNext  = document.getElementById('lb-next');

      let currentIdx = 0;

      // Returns the currently visible (non-hidden) photo cards
      function visibleCards() {
        return Array.from(document.querySelectorAll('[data-lightbox]'))
          .filter((c) => c.getAttribute('data-hidden') !== 'true');
      }

      function populate(card) {
        const src      = card.dataset.src || '';
        const alt      = card.dataset.alt || '';
        const title    = card.dataset.title || '';
        const location = card.dataset.location || '';
        const dateStr  = card.dataset.date || '';
        const camera   = card.dataset.camera || '';
        const lens     = card.dataset.lens || '';
        const exposure = card.dataset.exposure || '';

        const yr = dateStr ? new Date(dateStr).getFullYear() : '';
        const locLine = [location, yr].filter(Boolean).join(' · ');

        lbImg.src = src;
        lbImg.alt = alt;
        lbTitle.textContent = title;
        lbLoc.textContent = locLine;
        lbCam.textContent = camera;
        lbLens.textContent = lens;
        lbExp.textContent = exposure;
      }

      function updateArrows(cards) {
        lbPrev.hidden = currentIdx <= 0;
        lbNext.hidden = currentIdx >= cards.length - 1;
      }

      function open(card) {
        const cards = visibleCards();
        currentIdx = cards.indexOf(card);
        populate(card);
        updateArrows(cards);

        lb.hidden = false;
        requestAnimationFrame(() => lb.classList.add('lb-visible'));
        document.body.style.overflow = 'hidden';
        lbClose.focus();
      }

      function close() {
        lb.classList.remove('lb-visible');
        setTimeout(() => {
          lb.hidden = true;
          lbImg.src = '';
          document.body.style.overflow = '';
        }, 200);
      }

      function navigate(dir) {
        const cards = visibleCards();
        const next = currentIdx + dir;
        if (next < 0 || next >= cards.length) return;
        currentIdx = next;
        populate(cards[currentIdx]);
        updateArrows(cards);
      }

      // Open on card click
      document.querySelectorAll('[data-lightbox]').forEach((card) => {
        card.addEventListener('click', (e) => {
          e.preventDefault();
          open(card);
        });
      });

      // Arrow buttons
      lbPrev.addEventListener('click', (e) => { e.stopPropagation(); navigate(-1); });
      lbNext.addEventListener('click', (e) => { e.stopPropagation(); navigate(+1); });

      // Close on button / backdrop / ESC; arrows on ←→
      lbClose.addEventListener('click', close);
      lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape')     close();
        if (e.key === 'ArrowLeft')  navigate(-1);
        if (e.key === 'ArrowRight') navigate(+1);
      });
    })();
  </script>
</BaseLayout>
